{
  "permissions": {
    "allow": [
      "Bash(node harness/ruview/bin/cli.js*)",
      "mcp__ruview__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "mcpServers": {
    "ruview": {
      "command": "node",
      "args": ["${CLAUDE_PROJECT_DIR}/harness/ruview/bin/cli.js", "mcp", "start"]
    }
  }
}
